# Backend root URL — must match the mobile app’s EXPO_PUBLIC_BACKEND_URL.
# Spring Boot uses server.servlet.context-path=/api, so the value must end with /api.
#
# If the marketing site is served over HTTPS (e.g. trivaller.com on Vercel), the API URL
# must be HTTPS too — http:// will be blocked by the browser (“Failed to fetch”).
#
# Examples:
#   VITE_API_BASE_URL=https://api.trivaller.com/api
#   VITE_API_BASE_URL=https://trivaller.com/api
#
# Set this in your host (Vercel / Netlify / etc.) for production builds.
#
# Local website dev (npm run dev): copy to .env — port must match a RUNNING backend.
# Spring default in application.properties is 8081; your machine may use 8080.
# VITE_API_BASE_URL=http://localhost:8081/api
# VITE_API_BASE_URL=http://localhost:8080/api
#
# Point at EC2 from local dev (HTTP page → HTTP API is OK):
# VITE_API_BASE_URL=http://YOUR_EC2_PUBLIC_IP:8080/api
VITE_API_BASE_URL=http://localhost:8081/api
