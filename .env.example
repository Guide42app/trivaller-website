# Backend root URL — must match the mobile app’s EXPO_PUBLIC_BACKEND_URL.
# Spring Boot uses server.servlet.context-path=/api, so the value must end with /api.
#
# If the marketing site is served over HTTPS (e.g. trivaller.com on Vercel), VITE_API_BASE_URL
# must use https:// as well. Otherwise the browser blocks the request (mixed content → “Failed to fetch”).
#
# Typical fix on EC2: put nginx in front of Spring, terminate TLS with Let’s Encrypt (e.g. certbot
# --nginx), proxy_pass to http://127.0.0.1:8080 (Spring still uses context-path /api). Then set
# on Vercel: VITE_API_BASE_URL=https://your-api-hostname/api
#
# Until you have HTTPS on the API, use /admin only from http://localhost during dev (HTTP → HTTP is OK).
#
# Examples:
#   VITE_API_BASE_URL=https://api.trivaller.com/api
#   VITE_API_BASE_URL=https://trivaller.com/api
#
# Set this in your host (Vercel / Netlify / etc.) for production builds.
#
# Local website dev (npm run dev): copy to .env — port must match a RUNNING backend.
# Spring default in application.properties is 8081; your machine may use 8080.
# VITE_API_BASE_URL=http://localhost:8081/api
# VITE_API_BASE_URL=http://localhost:8080/api
#
# Point at EC2 over plain HTTP from local dev only (HTTP page → HTTP API is OK).
# Do not use this when the site is served over HTTPS — use an https:// API URL instead.
# Do not use https:// with a bare IP (e.g. https://1.2.3.4:8080) — Spring on 8080 is HTTP-only;
# use a domain + reverse proxy + TLS instead.
# VITE_API_BASE_URL=http://YOUR_EC2_PUBLIC_IP:8080/api
VITE_API_BASE_URL=http://localhost:8081/api
